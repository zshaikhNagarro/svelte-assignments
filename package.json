{
	"name": "myapp",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "pnpm --filter myapp dev",
		"build": "pnpm --filter myapp build",
		"preview": "pnpm --filter myapp preview",
		"dev:ui": "pnpm --filter @myorg/ui build --watch",
		"dev:all": "pnpm -w -r dev",
		"build:all": "pnpm -w -r build",
		"storybook": "pnpm --filter myapp storybook",
		"build-storybook": "pnpm --filter myapp build-storybook",
		"prepare": "pnpm -r prepare",
		"check": "pnpm --filter myapp check",
		"check:watch": "pnpm --filter myapp check:watch"
	},
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"devDependencies": {
		"@fontsource/fira-mono": "^5.2.7",
		"@neoconfetti/svelte": "^2.2.2",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@storybook/addon-essentials": "^7.0.0",
		"@storybook/builder-vite": "^7.0.0",
		"@storybook/sveltekit": "^7.0.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16"
	}
}
